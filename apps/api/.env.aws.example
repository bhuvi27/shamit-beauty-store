# Copy to .env.aws on EC2: cp .env.aws.example .env.aws
# Service hostnames match docker-compose.prod.yml (not localhost).

DEBUG=false

DATABASE_URL=postgresql+asyncpg://beauty:beauty@postgres:5432/beauty_store
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=beauty_catalog
REDIS_URL=redis://redis:6379/0

# Comma-separated browser origins (no trailing slash).
# GitHub Pages demo + CloudFront AWS shop + local dev:
#   https://YOUR_USERNAME.github.io,https://d111111abcdef8.cloudfront.net,http://localhost:3001
CORS_ORIGINS=https://YOUR_USERNAME.github.io,https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net,http://localhost:3001

JWT_ACCESS_SECRET=change-me-to-a-random-32-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-string

ADMIN_EMAIL=admin@beauty-store.local
ADMIN_PASSWORD=Admin123!

S3_ENDPOINT=http://minio:9000
S3_REGION=ap-south-1
S3_BUCKET=beauty-products
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Replace ELASTIC_IP with your EC2 public IP if serving MinIO assets externally.
S3_PUBLIC_URL=http://ELASTIC_IP:9000/beauty-products
S3_FORCE_PATH_STYLE=true

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
