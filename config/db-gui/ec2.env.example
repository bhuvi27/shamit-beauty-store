# Copy: cp config/db-gui/ec2.env.example config/db-gui/ec2.env
# Fill EC2_HOST and POSTGRES_PASSWORD. SSH key from terraform output (gitignored *.pem).

DB_GUI_TARGET=ec2

EC2_HOST=YOUR_EC2_PUBLIC_IP
SSH_KEY=infra/terraform/ec2-learning/beauty-store-learning.pem

POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=beauty_store
POSTGRES_USER=beauty
POSTGRES_PASSWORD=

MONGODB_URI=mongodb://localhost:27018/beauty_catalog

REDIS_HOST=localhost
REDIS_PORT=16379

POSTGRES_JDBC=jdbc:postgresql://localhost:15432/beauty_store
