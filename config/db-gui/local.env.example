# Copy: cp config/db-gui/local.env.example config/db-gui/local.env
# Use the same Postgres user/password as docker-compose.yml (local dev).

DB_GUI_TARGET=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beauty_store
POSTGRES_USER=beauty
POSTGRES_PASSWORD=

MONGODB_URI=mongodb://localhost:27017/beauty_catalog

REDIS_HOST=localhost
REDIS_PORT=6379

POSTGRES_JDBC=jdbc:postgresql://localhost:5432/beauty_store
