# Python API (apps/api/.env)
# See apps/api/.env.example for full list

# Web (web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Legacy / optional
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgresql://beauty:beauty@localhost:5432/beauty_store

# MongoDB
MONGODB_URI=mongodb://localhost:27017/beauty_catalog

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=beauty-products
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/beauty-products
S3_FORCE_PATH_STYLE=true

# Razorpay (test keys from dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxx

# Email (optional for MVP - logs if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@beauty-store.local

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Admin seed
ADMIN_EMAIL=admin@beauty-store.local
ADMIN_PASSWORD=Admin123!
