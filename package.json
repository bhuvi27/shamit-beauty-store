{
  "name": "beauty-store",
  "private": true,
  "workspaces": ["web"],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "api:install": "cd apps/api && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "api:migrate": "cd apps/api && . .venv/bin/activate && alembic upgrade head",
    "api:seed": "cd apps/api && . .venv/bin/activate && python -m scripts.seed",
    "api:dev": "cd apps/api && . .venv/bin/activate && uvicorn app.main:app --reload --port 3000",
    "web:dev": "npm run dev -w @beauty-store/web",
    "web:install": "npm install"
  }
}
